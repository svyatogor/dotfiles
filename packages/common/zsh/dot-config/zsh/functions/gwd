local branch=$1

if [[ -z "$branch" ]]; then
  echo "Usage: gwd <branch-name>"
  return 1
fi

local folder_name=${branch//\\//-}
local wt_root
wt_root=$(dirname "$(git rev-parse --absolute-git-dir)")
local target_path="$wt_root/$folder_name"

if [[ ! -d "$target_path" ]]; then
  echo "Worktree not found: $target_path"
  return 1
fi

git worktree remove "$target_path" && echo "Removed worktree: $target_path"
