{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "ruby -c *": "allow",
      "bundle exec ruby -c *": "allow",
      "bundle exec rspec *": "allow",
