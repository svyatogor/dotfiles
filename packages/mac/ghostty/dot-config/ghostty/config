theme = vague-light.ghostty
# theme = dark:Catppuccin Frappe,light:Catppuccin Latte

shell-integration = zsh
shell-integration-features = true
clipboard-read = allow

background-opacity = 0.92
window-colorspace = display-p3
background-blur = macos-glass-regular
# background-blur = 50

window-padding-balance = true
window-padding-x = 4
window-padding-y = 8

macos-titlebar-style = hidden
macos-option-as-alt = true

font-size = 14
adjust-cell-height = 20%
font-family = IoskeleyMonoTerm Nerd Font
font-style = SemiCondensed
font-style-italic = SemiCondensed Italic
# font-family = MonoLisa
# font-family = Maple Mono NF
# font-family = Lilex

# Tmux shortcuts implemented as terminal-side key sequences.
# Ctrl+1 sends \x02 (Ctrl+B, tmux's default prefix), then the literal 1;
# Ctrl+2 through Ctrl+9 do the same with their respective digit.
# These are equivalent to pressing prefix + number, not distinct Ctrl+number keys.
keybind = ctrl+1=text:\x021
keybind = ctrl+2=text:\x022
keybind = ctrl+3=text:\x023
keybind = ctrl+4=text:\x024
keybind = ctrl+5=text:\x025
keybind = ctrl+6=text:\x026
keybind = ctrl+7=text:\x027
keybind = ctrl+8=text:\x028
keybind = ctrl+9=text:\x029
# Ctrl+Tab sends Ctrl+B followed by l, equivalent to prefix + l (last window).
keybind = ctrl+tab=text:\x02l
# Shift+Enter sends Escape followed by carriage return, equivalent to Alt+Enter.
keybind = shift+enter=text:\x1b\r
# Cmd+K → clear screen + scrollback (sends C-S-l, bound in tmux and fish)
keybind = super+k=text:\x1b[76;6u

# Russian Phonetic layout: force Ctrl+<cyrillic> → correct control codes
keybind = ctrl+а=text:\x01
keybind = ctrl+б=text:\x02
keybind = ctrl+ц=text:\x03
keybind = ctrl+д=text:\x04
keybind = ctrl+е=text:\x05
keybind = ctrl+ф=text:\x06
keybind = ctrl+г=text:\x07
keybind = ctrl+х=text:\x08
keybind = ctrl+и=text:\x09
keybind = ctrl+к=text:\x0b
keybind = ctrl+л=text:\x0c
keybind = ctrl+н=text:\x0e
keybind = ctrl+о=text:\x0f
keybind = ctrl+п=text:\x10
keybind = ctrl+я=text:\x11
keybind = ctrl+р=text:\x12
keybind = ctrl+с=text:\x13
keybind = ctrl+т=text:\x14
keybind = ctrl+у=text:\x15
keybind = ctrl+в=text:\x16
keybind = ctrl+ш=text:\x17
keybind = ctrl+ь=text:\x18
keybind = ctrl+ы=text:\x19
keybind = ctrl+з=text:\x1a
